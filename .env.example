# Clave de API para Brevo (antiguo Sendinblue) para envío de correos desde formularios web.
# Obtén tu clave en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=tu_api_key_de_brevo_aqui

# Clave de API de Gemini de Google para el chat agéntico de asesoría energética.
# Obtén tu clave gratuita en: https://aistudio.google.com/
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

